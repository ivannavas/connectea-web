#!/bin/bash
# Post-commit hook: runs Claude Code agents for visual and SEO review

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Connectea Web — Post-Commit Agent Review"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

VISUAL_PROMPT="You are the visual-reviewer agent for the Connectea landing page. \
Review src/layouts/LandingPage.astro per the instructions in .claude/agents/visual-reviewer.md. \
Identify the top 2-3 visual improvements and apply them directly to the file."

SEO_PROMPT="You are the seo-reviewer agent for the Connectea landing page. \
Review src/layouts/LandingPage.astro and src/i18n/translations.ts per .claude/agents/seo-reviewer.md. \
Identify SEO issues and fix them directly in the files."

# Resolve claude command (handles Windows PATH issues)
CLAUDE_CMD=""
if command -v claude &> /dev/null; then
  CLAUDE_CMD="claude"
elif command -v claude.exe &> /dev/null; then
  CLAUDE_CMD="claude.exe"
elif [ -n "$CLAUDE_CODE_GIT_BASH_PATH" ]; then
  CLAUDE_CMD="$CLAUDE_CODE_GIT_BASH_PATH"
fi

if [ -z "$CLAUDE_CMD" ]; then
  echo ""
  echo "  ⚠️  'claude' CLI not found in PATH."
  echo "  To enable auto-review, add Claude Code to your PATH."
  echo "  Or set: export CLAUDE_CODE_GIT_BASH_PATH=/path/to/claude.exe"
  echo ""
  echo "  Run agents manually with:"
  echo "    claude --agent visual-reviewer"
  echo "    claude --agent seo-reviewer"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  exit 0
fi

echo ""
echo "🎨 Running visual design review..."
"$CLAUDE_CMD" --dangerously-skip-permissions -p "$VISUAL_PROMPT" 2>&1

echo ""
echo "🔍 Running SEO review..."
"$CLAUDE_CMD" --dangerously-skip-permissions -p "$SEO_PROMPT" 2>&1

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Review complete. Check 'git status' for changes."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
