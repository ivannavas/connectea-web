    .security-grid, .plugins-grid { grid-template-columns: 1fr; gap: 48px; }
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-top { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-cta { display: none; }
    .mobile-menu-btn { display: flex; }
    .mobile-menu.open {
      display: flex; flex-direction: column; gap: 8px;
      padding: 16px 24px; border-top: 1px solid var(--border-subtle);
      background: rgba(9,9,15,0.98);
    }
    .mobile-menu a { padding: 10px 14px; border-radius: var(--radius-sm); color: var(--text-secondary); font-size: 0.95rem; }
    .mobile-menu a:hover { background: var(--bg-card); color: var(--text); }
    .mobile-lang { display: flex; gap: 8px; padding: 6px 0; }
    .mobile-menu .btn { justify-content: center; margin-top: 8px; }
    .hero-title { font-size: clamp(2rem, 7vw, 3rem); }
    .hero-stats { flex-wrap: wrap; gap: 24px; }
    .features-grid { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: 1fr; gap: 40px; }
    .steps-grid::before { display: none; }
    .pricing-grid { grid-template-columns: 1fr; }
    .footer-top { grid-template-columns: 1fr; gap: 36px; }
    .footer-bottom { flex-direction: column; gap: 16px; }
    #features, #how, #security, #plugins, #pricing, #download { padding: 64px 0; }
  }

  @media (max-width: 480px) {
    .hero-actions { flex-direction: column; }
    .btn-lg { width: 100%; justify-content: center; }
    .app-window { transform: none; animation: none; }
    .pricing-card { padding: 24px; }
  }

  /* ===== ROOM JOIN OVERLAY ===== */
  .rjo-backdrop {
    position: fixed; inset: 0; z-index: 500;
    background: rgba(9, 9, 15, 0.85);
    backdrop-filter: blur(12px) saturate(1.4);
    display: flex; align-items: center; justify-content: center;
    padding: 24px;
    animation: rjo-fade-in 0.25s ease;
  }
  .rjo-backdrop[hidden] { display: none; }

  @keyframes rjo-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .rjo-card {
    position: relative;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 40px 36px 32px;
    max-width: 420px;
    width: 100%;
    text-align: center;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6), var(--shadow-glow);
    animation: rjo-slide-up 0.3s ease;
  }

  @keyframes rjo-slide-up {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .rjo-glow {
    position: absolute; inset: 0; border-radius: inherit; pointer-events: none;
    background: radial-gradient(ellipse at 50% 0%, rgba(99,102,241,0.18) 0%, transparent 65%);
  }

  .rjo-logo {
    width: 56px; height: 56px;
    background: var(--gradient);
    border-radius: var(--radius);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
    box-shadow: 0 8px 24px rgba(99,102,241,0.4);
  }

  .rjo-eyebrow {
    font-size: 0.72rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--primary-light); margin-bottom: 8px;
  }

  .rjo-title {
    font-size: 1.4rem; font-weight: 800; letter-spacing: -0.02em;
    line-height: 1.2; margin-bottom: 16px;
  }

  .rjo-room-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.3);
    border-radius: 8px; padding: 6px 14px; margin-bottom: 24px;
    font-size: 0.82rem; font-weight: 600; font-family: monospace;
    color: var(--primary-light);
  }

  .rjo-username-wrapper { margin-bottom: 20px; text-align: left; }

  .rjo-label {
    display: block; font-size: 0.8rem; font-weight: 600;
    color: var(--text-secondary); margin-bottom: 8px;
  }

  .rjo-input-row { display: flex; }

  .rjo-input {
    flex: 1; background: rgba(255,255,255,0.04); border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm); padding: 10px 14px;
    font-size: 0.92rem; color: var(--text); font-family: var(--font);
    outline: none; transition: border-color 0.2s, box-shadow 0.2s;
  }
  .rjo-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(99,102,241,0.2); }

  .rjo-error {
    margin-top: 6px; font-size: 0.78rem; color: var(--red);
  }
  .rjo-error[hidden] { display: none; }

  .rjo-btn {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; padding: 12px 20px; border-radius: var(--radius-sm);
    font-size: 0.95rem; font-weight: 600; font-family: var(--font);
    cursor: pointer; border: none; transition: all 0.2s ease;
    text-decoration: none; margin-bottom: 10px;
  }
  .rjo-btn-primary {
    background: var(--gradient); color: white;
  }
  .rjo-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(99,102,241,0.45); }

  .rjo-btn-secondary {
    background: transparent; color: var(--text-secondary);
    border: 1px solid var(--border-subtle) !important;
  }
  .rjo-btn-secondary:hover { background: var(--bg-card-hover); color: var(--text); }

  .rjo-dismiss {
    position: absolute; top: 14px; right: 14px;
    background: transparent; border: none; cursor: pointer;
    color: var(--text-muted); padding: 6px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s, color 0.15s;
  }
  .rjo-dismiss:hover { background: var(--bg-card); color: var(--text); }

  /* ===== PRICING CTA ===== */
  .pricing-cta { margin-top: 24px; }

  /* ===== FLOATING HERO BADGES ===== */
  .float-badge {
    position: absolute;
    display: inline-flex; align-items: center; gap: 7px;
    padding: 7px 13px; border-radius: 100px;
    font-size: 0.72rem; font-weight: 600;
    backdrop-filter: blur(16px) saturate(1.4);
    white-space: nowrap; pointer-events: none; z-index: 10;
  }
  .float-badge svg { flex-shrink: 0; }
  .float-badge-tl {
    top: -14px; left: 18px;
    background: rgba(99,102,241,0.15); border: 1px solid rgba(99,102,241,0.3);
    color: var(--primary-light);
    animation: floatBadge 5s ease-in-out infinite;
  }
  .float-badge-tr {
    top: 70px; right: -40px;
    background: rgba(34,211,238,0.1); border: 1px solid rgba(34,211,238,0.25);
    color: var(--teal-light);
    animation: floatBadge 6.5s ease-in-out infinite 0.9s;
  }
  .float-badge-br {
    bottom: 80px; right: -40px;
    background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.25);
    color: var(--green-light);
    animation: floatBadge 7s ease-in-out infinite 1.8s;
  }
  @keyframes floatBadge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-7px); }
  }
  @media (max-width: 900px) { .float-badge { display: none; } }
</style>

<script>
  // Scroll-triggered reveal
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); observer.unobserve(e.target); } }),
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));

  // Nav scroll state
  const nav = document.getElementById('nav');
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 60);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  menuBtn?.addEventListener('click', () => {
    const open = mobileMenu?.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded', String(open));
  });
  mobileMenu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => { mobileMenu.classList.remove('open'); menuBtn?.setAttribute('aria-expanded', 'false'); });
  });

  // ── Room join overlay ──────────────────────────────────────
  // Activated when the URL hash is #download?room-id=xxx
  // (the link format generated by the app's Share > Copy Link button)
  (() => {
    const hash = window.location.hash; // e.g. "#download?room-id=abc123"
    if (!hash.startsWith('#download?')) return;

    const queryPart = hash.slice('#download?'.length);
    const params = new URLSearchParams(queryPart);
    const roomId = params.get('room-id');
    if (!roomId) return;

    const lang = document.documentElement.lang || 'en';

    const i18n = {
      en: {
        eyebrow: "You've been invited",
        title: "Join this Connectea room",
        label: "Your name",
        openBtn: "Open in Connectea",
        downloadBtn: "Download Connectea first",
        errorEmpty: "Please enter your name.",
        errorInvalid: "Use 2–32 letters, numbers, dashes, dots, underscores or spaces.",
      },
      es: {
        eyebrow: "Has sido invitado",
        title: "Unirse a esta sala de Connectea",
        label: "Tu nombre",
        openBtn: "Abrir en Connectea",
        downloadBtn: "Descargar Connectea primero",
        errorEmpty: "Por favor ingresa tu nombre.",
        errorInvalid: "Usa 2–32 letras, números, guiones, puntos, guiones bajos o espacios.",
      },
      zh: {
        eyebrow: "您收到了邀请",
        title: "加入此 Connectea 房间",
        label: "你的名字",
        openBtn: "在 Connectea 中打开",
        downloadBtn: "先下载 Connectea",
        errorEmpty: "请输入您的名字。",
        errorInvalid: "使用 2–32 个字母、数字、连字符、点、下划线或空格。",
      },
    };

    const tx = i18n[lang] || i18n.en;
    const USERNAME_RE = /^[\p{L}\p{N}][\p{L}\p{N}_\-. ]{1,31}$/u;
    const STORAGE_KEY = 'connectea-web-user';

    const overlay   = document.getElementById('room-join-overlay');
    const roomIdEl  = document.getElementById('rjo-room-id');
    const eyebrowEl = document.getElementById('rjo-eyebrow-text');
    const titleEl   = document.getElementById('rjo-title');
    const labelEl   = document.getElementById('rjo-label-text');
    const input     = document.getElementById('rjo-username-input');
    const openBtn   = document.getElementById('rjo-open-btn');
    const openBtnTx = document.getElementById('rjo-open-btn-text');
    const dlBtnTx   = document.getElementById('rjo-download-btn-text');
    const errorEl   = document.getElementById('rjo-error');
    const dismissBtn = document.getElementById('rjo-dismiss-btn');

    eyebrowEl.textContent  = tx.eyebrow;
    titleEl.textContent    = tx.title;
    labelEl.textContent    = tx.label;
    openBtnTx.textContent  = tx.openBtn;
    dlBtnTx.textContent    = tx.downloadBtn;

    // Show (truncated) room ID
    roomIdEl.textContent = roomId.length > 20 ? roomId.slice(0, 20) + '…' : roomId;

    // Pre-fill stored username
    const storedUser = localStorage.getItem(STORAGE_KEY) || '';
    input.value = storedUser;
    input.placeholder = tx.label;

    const buildDeepLink = (user) =>
      `connectea://join?room-id=${encodeURIComponent(roomId)}&user=${encodeURIComponent(user)}`;

    const showError = (msg) => {
      errorEl.textContent = msg;
      errorEl.hidden = false;
    };

    const hideError = () => { errorEl.hidden = true; };

    openBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const name = input.value.trim();
      if (!name) { showError(tx.errorEmpty); return; }
      if (!USERNAME_RE.test(name)) { showError(tx.errorInvalid); return; }
      hideError();
      localStorage.setItem(STORAGE_KEY, name);
      window.location.href = buildDeepLink(name);
    });

    input.addEventListener('input', hideError);

    dismissBtn.addEventListener('click', () => {
      overlay.hidden = true;
      // Clear the hash without reloading so the page stays put
      history.replaceState(null, '', window.location.pathname + window.location.search);
    });

    overlay.hidden = false;
  })();
</script>
