---
import type { Translation, Lang } from '../i18n/translations';

interface Props {
  t: Translation;
  lang: Lang;
}

const { t, lang } = Astro.props;

const langLabels: Record<Lang, string> = { en: 'EN', es: 'ES', zh: '中文' };
const otherLangs = (['en', 'es', 'zh'] as Lang[]).filter(l => l !== lang);
---

<!DOCTYPE html>
<html lang={lang} dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t.meta.title}</title>
  <meta name="description" content={t.meta.description} />
  <meta name="keywords" content={t.meta.keywords} />
  <meta name="robots" content="index, follow" />

  <!-- Canonical & hreflang -->
  <link rel="canonical" href={`https://connectea.net/${lang}/`} />
  <link rel="alternate" hreflang="en" href="https://connectea.net/en/" />
  <link rel="alternate" hreflang="es" href="https://connectea.net/es/" />
  <link rel="alternate" hreflang="zh" href="https://connectea.net/zh/" />
  <link rel="alternate" hreflang="x-default" href="https://connectea.net/en/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://connectea.net/${lang}/`} />
  <meta property="og:title" content={t.meta.title} />
  <meta property="og:description" content={t.meta.description} />
  <meta property="og:image" content="https://connectea.net/og-image.png" />
  <meta property="og:site_name" content="Connectea" />
  <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : lang === 'es' ? 'es_ES' : 'en_US'} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={t.meta.title} />
  <meta name="twitter:description" content={t.meta.description} />
  <meta name="twitter:image" content="https://connectea.net/og-image.png" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Connectea",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Windows 10, Windows 11",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": t.meta.description,
    "url": "https://connectea.net",
    "downloadUrl": "https://connectea.net/downloads/connectea-setup.exe",
    "featureList": "End-to-end encryption, Real-time collaboration, File sharing, Access control, Plugin ecosystem",
    "softwareVersion": "1.0",
    "author": { "@type": "Organization", "name": "Connectea" },
    "inLanguage": lang === 'zh' ? 'zh-Hans' : lang === 'es' ? 'es' : 'en',
  })} />
</head>
<body>

  <!-- Background decoration -->
  <div class="bg-deco" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <!-- ============ NAVIGATION ============ -->
  <nav id="nav" role="navigation" aria-label="Main navigation">
    <div class="container nav-inner">
      <a href={`/${lang}/`} class="logo" aria-label="Connectea home">
        <div class="logo-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 32 32" fill="none">
            <circle cx="10" cy="16" r="4" fill="white"/>
            <circle cx="24" cy="9" r="3" fill="white" opacity="0.85"/>
            <circle cx="24" cy="23" r="3" fill="white" opacity="0.85"/>
            <line x1="10" y1="16" x2="24" y2="9" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
            <line x1="10" y1="16" x2="24" y2="23" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
          </svg>
        </div>
        <span>Connectea</span>
      </a>

      <div class="nav-links" role="list">
        <a href="#features" role="listitem">{t.nav.features}</a>
        <a href="#security" role="listitem">{t.nav.security}</a>
        <a href="#plugins" role="listitem">{t.nav.plugins}</a>
        <a href="#pricing" role="listitem">{t.nav.pricing}</a>
      </div>

      <div class="nav-right">
        <div class="lang-switcher" role="group" aria-label="Language selector">
          {(['en', 'es', 'zh'] as Lang[]).map(l => (
            <a href={`/${l}/`} class={`lang-btn${l === lang ? ' active' : ''}`} aria-current={l === lang ? 'true' : undefined} lang={l}>
              {langLabels[l]}
            </a>
          ))}
        </div>
        <a href="#download" class="btn btn-primary nav-cta">{t.nav.download}</a>
        <button class="mobile-menu-btn" id="menuBtn" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
    <!-- Mobile menu -->
    <div class="mobile-menu" id="mobileMenu" role="menu">
      <a href="#features" role="menuitem">{t.nav.features}</a>
      <a href="#security" role="menuitem">{t.nav.security}</a>
      <a href="#plugins" role="menuitem">{t.nav.plugins}</a>
      <a href="#pricing" role="menuitem">{t.nav.pricing}</a>
      <div class="mobile-lang">
        {(['en', 'es', 'zh'] as Lang[]).map(l => (
          <a href={`/${l}/`} class={`lang-btn${l === lang ? ' active' : ''}`} lang={l}>
            {langLabels[l]}
          </a>
        ))}
      </div>
      <a href="#download" class="btn btn-primary">{t.nav.download}</a>
    </div>
  </nav>

  <!-- ============ HERO ============ -->
  <section id="hero" aria-labelledby="hero-title">
    <div class="container hero-grid">
      <div class="hero-content" data-reveal>
        <div class="badge badge-primary">{t.hero.badge}</div>
        <h1 id="hero-title" class="hero-title">
          {lang === 'zh'
            ? <><span>{t.hero.headline.slice(0, -4)}</span><span class="gradient-text">{t.hero.headline.slice(-4)}</span></>
            : <><span>{t.hero.headline.split(' ').slice(0, -2).join(' ')}</span>{' '}<span class="gradient-text">{t.hero.headline.split(' ').slice(-2).join(' ')}</span></>
          }
        </h1>
        <p class="hero-subtitle">{t.hero.subheadline}</p>
        <div class="hero-actions">
          <a href="#download" class="btn btn-primary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            {t.hero.cta_primary}
          </a>
          <a href="#features" class="btn btn-outline btn-lg">
            {t.hero.cta_secondary}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
        <div class="hero-stats" role="list">
          {t.hero.stats.map(stat => (
            <div class="stat" role="listitem">
              <div class="stat-value">{stat.value}</div>
              <div class="stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- App window mockup -->
      <div class="hero-visual" aria-hidden="true" data-reveal>
        <div class="app-window">
          <div class="app-titlebar">
            <div class="titlebar-dots">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <span class="titlebar-title">Connectea</span>
            <div style="width:52px"></div>
          </div>
          <div class="app-body">
            <div class="app-sidebar">
              <div class="sidebar-label">ROOMS</div>
              <div class="room-item active">
                <span class="room-dot"></span>
                <span>ABC-1234</span>
              </div>
              <div class="room-item">
                <span class="room-dot dim"></span>
                <span>DEF-5678</span>
              </div>
              <div class="room-item">
                <span class="room-dot dim"></span>
                <span>GHI-9012</span>
              </div>
              <div class="room-add">+ New Room</div>
            </div>
            <div class="app-main">
              <div class="app-header-bar">
                <span class="room-code-badge">ABC-1234</span>
                <span class="owner-badge">Owner</span>
              </div>
              <div class="file-list">
                <div class="file-row">
                  <span class="file-icon">📄</span>
                  <span class="file-name">report_q4.pdf</span>
                  <span class="file-size">2.3 MB</span>
                  <span class="enc-badge">🔒</span>
                </div>
                <div class="file-row">
                  <span class="file-icon">📁</span>
                  <span class="file-name">assets/</span>
                  <span class="file-size">12 MB</span>
                  <span class="enc-badge">&nbsp;</span>
                </div>
                <div class="file-row">
                  <span class="file-icon">🎵</span>
                  <span class="file-name">audio_master.mp3</span>
                  <span class="file-size">8.1 MB</span>
                  <span class="enc-badge">🔒</span>
                </div>
                <div class="file-row">
                  <span class="file-icon">📝</span>
                  <span class="file-name">notes.txt</span>
                  <span class="file-size">12 KB</span>
                  <span class="enc-badge">&nbsp;</span>
                </div>
              </div>
              <div class="app-toolbar">
                <button class="tool-btn tool-btn-primary">↑ Upload</button>
                <button class="tool-btn tool-btn-ghost">↓ Download All</button>
                <button class="tool-btn tool-btn-ghost">🔌 Plugins</button>
              </div>
            </div>
          </div>
        </div>
        <div class="window-glow"></div>
      </div>
    </div>
  </section>

  <!-- ============ FEATURES ============ -->
  <section id="features" aria-labelledby="features-title">
    <div class="container">
      <div class="section-header" data-reveal>
        <h2 id="features-title" class="section-title">{t.features.title}</h2>
        <p class="section-subtitle">{t.features.subtitle}</p>
      </div>
      <div class="features-grid">
        {t.features.items.map((item, i) => (
          <article class="feature-card" data-reveal style={`--delay: ${i * 0.08}s`}>
            <div class="feature-icon" aria-hidden="true">{item.icon}</div>
            <h3 class="feature-title">{item.title}</h3>
            <p class="feature-desc">{item.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section id="how" aria-labelledby="how-title">
    <div class="container">
      <div class="section-header" data-reveal>
        <h2 id="how-title" class="section-title">{t.howItWorks.title}</h2>
        <p class="section-subtitle">{t.howItWorks.subtitle}</p>
      </div>
      <div class="steps-grid">
        {t.howItWorks.steps.map((step, i) => (
          <div class="step" data-reveal style={`--delay: ${i * 0.12}s`}>
            <div class="step-num" aria-hidden="true">{step.number}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SECURITY ============ -->
  <section id="security" aria-labelledby="security-title">
    <div class="container">
      <div class="security-grid">
        <div class="security-content" data-reveal>
          <div class="badge badge-green">{t.security.badge}</div>
          <h2 id="security-title" class="section-title security-title">{t.security.title}</h2>
          <p class="section-subtitle">{t.security.subtitle}</p>
          <ul class="security-list" role="list">
            {t.security.points.map(point => (
              <li role="listitem">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {point}
              </li>
            ))}
          </ul>
        </div>
        <div class="security-visual" data-reveal>
          <div class="security-icon-wrap" aria-hidden="true">
            <div class="shield-outer">
              <div class="shield-inner">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
            </div>
          </div>
          <div class="crypto-label">AES-256-GCM</div>
          <div class="crypto-sub">Client-side encryption</div>
          <div class="crypto-badges">
            <span class="crypto-badge">PBKDF2</span>
            <span class="crypto-badge">SHA-256</span>
            <span class="crypto-badge">Zero-Knowledge</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PLUGINS ============ -->
  <section id="plugins" aria-labelledby="plugins-title">
    <div class="container">
      <div class="plugins-grid">
        <div class="plugins-content" data-reveal>
          <div class="badge badge-amber">{t.plugins.badge}</div>
          <h2 id="plugins-title" class="section-title">{t.plugins.title}</h2>
          <p class="section-subtitle">{t.plugins.subtitle}</p>
          <ul class="plugins-features" role="list">
            {t.plugins.features.map(feat => (
              <li role="listitem">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                {feat}
              </li>
            ))}
          </ul>
          <a href="#download" class="btn btn-outline" style="margin-top: 32px;">{t.plugins.cta}</a>
        </div>
        <div class="plugin-terminal" data-reveal aria-hidden="true">
          <div class="terminal-header">
            <div class="titlebar-dots">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <span class="terminal-title">Plugin Output</span>
            <div style="width:52px"></div>
          </div>
          <div class="terminal-body">
            <div><span class="t-muted">$</span> <span class="t-blue">connectea</span> plugin start data-processor</div>
            <div><span class="t-green">✓</span> Plugin initialized</div>
            <div><span class="t-amber">→</span> Processing room files...</div>
            <div class="t-muted">&nbsp;&nbsp;[████████████████] 100% (12/12)</div>
            <div><span class="t-green">✓</span> Analysis complete</div>
            <div class="t-muted">&nbsp;&nbsp;Found: 3 duplicates · 45.2 MB freed</div>
            <div><span class="t-amber">→</span> Generating report...</div>
            <div><span class="t-green">✓</span> report.json saved to /outputs/</div>
            <div><span class="t-muted">$</span> <span class="cursor"></span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PRICING ============ -->
  <section id="pricing" aria-labelledby="pricing-title">
    <div class="container">
      <div class="section-header" data-reveal>
        <h2 id="pricing-title" class="section-title">{t.pricing.title}</h2>
        <p class="section-subtitle">{t.pricing.subtitle}</p>
      </div>
      <div class="pricing-grid">
        <article class="pricing-card" data-reveal>
          <header class="pricing-header">
            <h3 class="pricing-tier">{t.pricing.free.title}</h3>
            <div class="pricing-price">{t.pricing.free.price}<span>/{t.pricing.free.period}</span></div>
          </header>
          <ul class="pricing-features" role="list">
            {t.pricing.free.features.map(f => (
              <li role="listitem">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="#download" class="btn btn-outline btn-full">{t.pricing.free.cta}</a>
        </article>

        <article class="pricing-card pricing-card-featured" data-reveal style="--delay: 0.1s">
          <header class="pricing-header">
            <h3 class="pricing-tier">
              {t.pricing.pro.title}
              <span class="pricing-badge">{t.pricing.pro.badge}</span>
            </h3>
            <div class="pricing-price gradient-text">{t.pricing.pro.price}<span>/{t.pricing.pro.period}</span></div>
          </header>
          <ul class="pricing-features" role="list">
            {t.pricing.pro.features.map(f => (
              <li role="listitem">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="#download" class="btn btn-primary btn-full">{t.pricing.pro.cta}</a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ DOWNLOAD CTA ============ -->
  <section id="download" aria-labelledby="download-title">
    <div class="container download-inner" data-reveal>
      <h2 id="download-title" class="download-title">{t.download.title}</h2>
      <p class="download-subtitle">{t.download.subtitle}</p>
      <a href="/downloads/connectea-setup.exe" class="btn btn-primary btn-download" download>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        {t.download.cta}
      </a>
      <p class="download-note">{t.download.note}</p>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->
  <footer role="contentinfo">
    <div class="container">
      <div class="footer-top">
        <div class="footer-brand">
          <a href={`/${lang}/`} class="logo footer-logo" aria-label="Connectea home">
            <div class="logo-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 32 32" fill="none">
                <circle cx="10" cy="16" r="4" fill="white"/>
                <circle cx="24" cy="9" r="3" fill="white" opacity="0.85"/>
                <circle cx="24" cy="23" r="3" fill="white" opacity="0.85"/>
                <line x1="10" y1="16" x2="24" y2="9" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
                <line x1="10" y1="16" x2="24" y2="23" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
              </svg>
            </div>
            <span>Connectea</span>
          </a>
          <p class="footer-tagline">{t.footer.tagline}</p>
        </div>

        <div class="footer-links-col">
          <h4 class="footer-links-title">{t.footer.product}</h4>
          <ul class="footer-links" role="list">
            <li><a href="#features">{t.footer.links.features}</a></li>
            <li><a href="#security">{t.footer.links.security}</a></li>
            <li><a href="#pricing">{t.footer.links.pricing}</a></li>
            <li><a href="#download">{t.footer.links.download}</a></li>
          </ul>
        </div>

        <div class="footer-links-col">
          <h4 class="footer-links-title">{t.footer.legal}</h4>
          <ul class="footer-links" role="list">
            <li><a href="#">{t.footer.links.privacy}</a></li>
            <li><a href="#">{t.footer.links.terms}</a></li>
            <li><a href="#">{t.footer.links.contact}</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-bottom">
        <p class="footer-copy">{t.footer.copyright}</p>
        <div class="footer-lang" role="group" aria-label="Language selector">
          {(['en', 'es', 'zh'] as Lang[]).map(l => (
            <a href={`/${l}/`} class={`lang-btn${l === lang ? ' active' : ''}`} lang={l}>
              {langLabels[l]}
            </a>
          ))}
        </div>
      </div>
    </div>
  </footer>

</body>
</html>

<style is:global>
  /* ===== VARIABLES ===== */
  :root {
    --bg: #09090f;
    --bg-surface: #0f0f1a;
    --bg-card: rgba(255, 255, 255, 0.035);
    --bg-card-hover: rgba(255, 255, 255, 0.06);
    --border: rgba(99, 102, 241, 0.25);
    --border-subtle: rgba(255, 255, 255, 0.07);

    --primary: #6366f1;
    --primary-light: #818cf8;
    --primary-dark: #4f46e5;
    --gradient: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    --gradient-text: linear-gradient(135deg, #a5b4fc 0%, #c084fc 100%);

    --text: #f1f5f9;
    --text-secondary: #94a3b8;
    --text-muted: #475569;

    --green: #22c55e;
    --green-light: #4ade80;
    --amber: #f59e0b;
    --red: #ef4444;

    --radius-sm: 8px;
    --radius: 12px;
    --radius-lg: 18px;
    --radius-xl: 24px;

    --shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    --shadow-glow: 0 0 48px rgba(99, 102, 241, 0.15);

    --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --container: 1200px;
  }

  /* ===== RESET ===== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; font-size: 16px; }
  body { background: var(--bg); color: var(--text); font-family: var(--font); line-height: 1.6; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
  a { text-decoration: none; color: inherit; }
  img, svg { display: block; }
  button { cursor: pointer; border: none; background: none; font-family: inherit; }
  ul { list-style: none; }

  /* ===== UTILS ===== */
  .container { max-width: var(--container); margin: 0 auto; padding: 0 24px; }
  .gradient-text { background: var(--gradient-text); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
  .section-header { text-align: center; max-width: 640px; margin: 0 auto 64px; }
  .section-title { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 16px; }
  .section-subtitle { font-size: 1.1rem; color: var(--text-secondary); line-height: 1.7; }

  /* ===== BADGES ===== */
