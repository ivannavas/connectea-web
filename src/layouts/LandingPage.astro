---
import type { Translation, Lang } from '../i18n/translations';

interface Props {
  t: Translation;
  lang: Lang;
}

const { t, lang } = Astro.props;

// ── Open source ────────────────────────────────────────────
const GH_PROFILE = 'https://github.com/ivannavas';
const GH_REPOS = {
  app: 'https://github.com/ivannavas/connectea',
  backend: 'https://github.com/ivannavas/connectea-backend',
  velocity: 'https://github.com/ivannavas/connectea-velocity',
  web: 'https://github.com/ivannavas/connectea-web',
};

const ossCopy = {
  en: {
    nav: 'GitHub',
    badge: 'Open Source',
    title: 'Connectea is now open source',
    subtitle: 'The Connectea project — desktop app, backend, Velocity proxy and this website — has been fully released as open source. Explore the code, self-host it, or contribute on GitHub.',
    viewAll: 'View on GitHub',
    footerCol: 'Open Source',
    repos: { app: 'Desktop app', backend: 'Backend', velocity: 'Velocity proxy', web: 'Website' },
  },
  es: {
    nav: 'GitHub',
    badge: 'Código abierto',
    title: 'Connectea ahora es de código abierto',
    subtitle: 'El proyecto Connectea —app de escritorio, backend, proxy Velocity y esta web— se ha liberado por completo como código abierto. Explora el código, hospédalo tú mismo o contribuye en GitHub.',
    viewAll: 'Ver en GitHub',
    footerCol: 'Código abierto',
    repos: { app: 'App de escritorio', backend: 'Backend', velocity: 'Proxy Velocity', web: 'Web' },
  },
  zh: {
    nav: 'GitHub',
    badge: '开源',
    title: 'Connectea 现已开源',
    subtitle: 'Connectea 项目——桌面应用、后端、Velocity 代理以及本网站——已完全开源。欢迎在 GitHub 上浏览代码、自行部署或参与贡献。',
    viewAll: '在 GitHub 上查看',
    footerCol: '开源',
    repos: { app: '桌面应用', backend: '后端', velocity: 'Velocity 代理', web: '网站' },
  },
} as const;
const oss = ossCopy[lang];

const langLabels: Record<Lang, string> = { en: 'EN', es: 'ES', zh: '中文' };
const otherLangs = (['en', 'es', 'zh'] as Lang[]).filter(l => l !== lang);
---

<!DOCTYPE html>
<html lang={lang} dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t.meta.title}</title>
  <meta name="description" content={t.meta.description} />
  <meta name="keywords" content={t.meta.keywords} />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#6366f1" />

  <!-- Sitemap -->
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

  <!-- Canonical & hreflang -->
  <link rel="canonical" href={`https://connectea.net/${lang}/`} />
  <link rel="alternate" hreflang="en" href="https://connectea.net/en/" />
  <link rel="alternate" hreflang="es" href="https://connectea.net/es/" />
  <link rel="alternate" hreflang="zh" href="https://connectea.net/zh/" />
  <link rel="alternate" hreflang="x-default" href="https://connectea.net/en/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://connectea.net/${lang}/`} />
  <meta property="og:title" content={t.meta.title} />
  <meta property="og:description" content={t.meta.description} />
  <meta property="og:image" content="https://connectea.net/icon.png" />
  <meta property="og:image:secure_url" content="https://connectea.net/icon.png" />
  <meta property="og:image:alt" content={lang === 'zh' ? 'Connectea — 大文件公开链接传输，永不过期，可选加密，无需账号。' : lang === 'es' ? 'Connectea — Envía archivos grandes con enlace público permanente. Cifrado E2E opcional. Sin cuenta.' : 'Connectea — Send large files with a permanent public link. Optional E2E encryption. No account needed.'} />
  <meta property="og:image:width" content="1080" />
  <meta property="og:image:height" content="1080" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:site_name" content="Connectea" />
  <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : lang === 'es' ? 'es_ES' : 'en_US'} />
  {otherLangs.map(l => (
    <meta property="og:locale:alternate" content={l === 'zh' ? 'zh_CN' : l === 'es' ? 'es_ES' : 'en_US'} />
  ))}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={t.meta.title} />
  <meta name="twitter:description" content={t.meta.description} />
  <meta name="twitter:image" content="https://connectea.net/icon.png" />
  <meta name="twitter:image:alt" content={lang === 'zh' ? 'Connectea — 大文件公开链接传输，永不过期，可选加密，无需账号。' : lang === 'es' ? 'Connectea — Envía archivos grandes con enlace público permanente. Cifrado E2E opcional. Sin cuenta.' : 'Connectea — Send large files with a permanent public link. Optional E2E encryption. No account needed.'} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="192x192" href="/favicon-192.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700;800&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" as="style" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700;800&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://connectea.net/#organization",
    "name": "Connectea",
    "url": "https://connectea.net",
    "email": "contact@connectea.net",
    "logo": {
      "@type": "ImageObject",
      "url": "https://connectea.net/og-image.png",
      "width": 1200,
      "height": 630,
    },
    "description": "Connectea provides large file transfers with no per-file size limit, one-click public sharing links, and free one-click Minecraft server hosting — no account required.",
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://connectea.net/#website",
    "url": "https://connectea.net",
    "name": "Connectea",
    "description": "Share files with friends instantly. No account, no email. One-click Minecraft server.",
    "publisher": { "@id": "https://connectea.net/#organization" },
    "inLanguage": ["en", "es", "zh-Hans"],
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Connectea",
    "applicationCategory": "UtilitiesApplication",
    "applicationSubCategory": "FileSharing",
    "operatingSystem": "Windows 10, Windows 11",
    "description": t.meta.description,
    "url": "https://connectea.net",
    "featureList": "No per-file size limit, Public file sharing links, One-click Minecraft server plugin, Instant file sharing with friends, No account required, AES-256-GCM end-to-end encryption, PBKDF2 key derivation, SHA-256 integrity verification, Code-based rooms, Drag-and-drop folders, Streamed ZIP download, READ/WRITE allowlist, English/Spanish/Chinese UI",
    "softwareVersion": "1.1.1",
    "datePublished": "2025-01-01",
    "dateModified": "2026-05-16",
    "author": { "@id": "https://connectea.net/#organization" },
    "publisher": { "@id": "https://connectea.net/#organization" },
    "inLanguage": lang === 'zh' ? 'zh-Hans' : lang === 'es' ? 'es' : 'en',
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": lang === 'es' ? [
      {
        "@type": "Question",
        "name": "¿Hay límite de tamaño por archivo en Connectea?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Connectea no impone ningún límite de tamaño por archivo. Puedes subir archivos de cualquier tamaño — vídeos 4K, backups completos, imágenes ISO. Los archivos se dividen automáticamente en fragmentos de 10 MB y se transfieren sin restricciones." }
      },
      {
        "@type": "Question",
        "name": "¿Cómo comparto un archivo con un enlace público en Connectea?",
        "acceptedAnswer": { "@type": "Answer", "text": "Como propietario de la sala, selecciona cualquier archivo subido, haz clic en «Hacer público» en el panel de detalles y copia el enlace. Quien reciba el enlace puede descargarlo directamente desde el navegador — sin cuenta de Connectea ni necesidad de instalar nada." }
      },
      {
        "@type": "Question",
        "name": "¿Cómo creo un servidor de Minecraft con Connectea?",
        "acceptedAnswer": { "@type": "Answer", "text": "Descarga Connectea, crea una sala y añade el plugin de Minecraft. Pulsa Iniciar — el servidor arranca automáticamente y los archivos del mundo se sincronizan con la sala. Sin configuración." }
      },
      {
        "@type": "Question",
        "name": "¿Necesito cuenta para usar Connectea?",
        "acceptedAnswer": { "@type": "Answer", "text": "No hace falta cuenta. Solo escribe un nombre, crea una sala o únete con un código, y empieza a compartir archivos al instante." }
      }
    ] : lang === 'zh' ? [
      {
        "@type": "Question",
        "name": "Connectea有单文件大小限制吗？",
        "acceptedAnswer": { "@type": "Answer", "text": "没有。Connectea不设单文件大小限制。你可以上传任意大小的文件——4K视频、完整游戏存档、ISO镜像。文件会自动分成10MB分块传输，没有人为限制。" }
      },
      {
        "@type": "Question",
        "name": "如何用Connectea生成公开分享链接？",
        "acceptedAnswer": { "@type": "Answer", "text": "作为房主，选择任意已上传的文件，在详情面板中点击「设为公开」并复制链接。收到链接的人可以直接在浏览器下载——无需Connectea账号，无需安装任何软件。" }
      },
      {
        "@type": "Question",
        "name": "如何使用Connectea创建Minecraft（我的世界）服务器？",
        "acceptedAnswer": { "@type": "Answer", "text": "下载Connectea，创建房间，添加Minecraft插件，点击启动——服务器自动启动，世界文件同步到房间。无需配置。" }
      },
      {
        "@type": "Question",
        "name": "使用Connectea需要账号吗？",
        "acceptedAnswer": { "@type": "Answer", "text": "不需要账号。只需输入名字，创建或加入房间，即可立即开始分享文件。" }
      }
    ] : [
      {
        "@type": "Question",
        "name": "Is there a file size limit in Connectea?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Connectea has no per-file size limit. You can upload files of any size — 4K videos, full game backups, ISO images. Files are automatically split into 10 MB chunks and transferred without restrictions." }
      },
      {
        "@type": "Question",
        "name": "How do I share a file with a public link in Connectea?",
        "acceptedAnswer": { "@type": "Answer", "text": "As the room owner, select any uploaded file, click 'Make Public' in the detail panel, and copy the link. Anyone with the link can download it directly from their browser — no Connectea account or app required." }
      },
      {
        "@type": "Question",
        "name": "How do I create a Minecraft server with Connectea?",
        "acceptedAnswer": { "@type": "Answer", "text": "Download Connectea, create a room, and add the Minecraft plugin. Hit Start — the server boots automatically and world files sync to the room. No configuration required." }
      },
      {
        "@type": "Question",
        "name": "Do I need an account to use Connectea?",
        "acceptedAnswer": { "@type": "Answer", "text": "No account needed. Just enter a name, create a room or join with a code, and start sharing files immediately." }
      }
    ],
  })} />

  <!-- TikTok Pixel Code Start -->
  <script is:inline>
  !function (w, d, t) {
    w.TiktokAnalyticsObject=t;var ttq=w[t]=w[t]||[];ttq.methods=["page","track","identify","instances","debug","on","off","once","ready","alias","group","enableCookie","disableCookie","holdConsent","revokeConsent","grantConsent"],ttq.setAndDefer=function(t,e){t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}};for(var i=0;i<ttq.methods.length;i++)ttq.setAndDefer(ttq,ttq.methods[i]);ttq.instance=function(t){for(
    var e=ttq._i[t]||[],n=0;n<ttq.methods.length;n++)ttq.setAndDefer(e,ttq.methods[n]);return e},ttq.load=function(e,n){var r="https://analytics.tiktok.com/i18n/pixel/events.js",o=n&&n.partner;ttq._i=ttq._i||{},ttq._i[e]=[],ttq._i[e]._u=r,ttq._t=ttq._t||{},ttq._t[e]=+new Date,ttq._o=ttq._o||{},ttq._o[e]=n||{};n=document.createElement("script")
    ;n.type="text/javascript",n.async=!0,n.src=r+"?sdkid="+e+"&lib="+t;e=document.getElementsByTagName("script")[0];e.parentNode.insertBefore(n,e)};
    ttq.load('D7TLODRC77U9E9A36KM0');
    ttq.page();
  }(window, document, 'ttq');
  </script>
  <!-- TikTok Pixel Code End -->

  <!-- Google Ads -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18149030492" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-18149030492');
  </script>
  <!-- Google Ads End -->
</head>
<body>

  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- Background decoration -->
  <div class="bg-deco" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <!-- ============ NAVIGATION ============ -->
  <nav id="nav" role="navigation" aria-label="Main navigation">
    <div class="container nav-inner">
      <a href={`/${lang}/`} class="logo" aria-label="Connectea home">
        <div class="logo-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 32 32" fill="none">
            <circle cx="10" cy="16" r="4" fill="white"/>
            <circle cx="24" cy="9" r="3" fill="white" opacity="0.85"/>
            <circle cx="24" cy="23" r="3" fill="white" opacity="0.85"/>
            <line x1="10" y1="16" x2="24" y2="9" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
            <line x1="10" y1="16" x2="24" y2="23" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
          </svg>
        </div>
        <span>Connectea</span>
      </a>

      <div class="nav-links" role="list">
        <a href="#features" role="listitem">{t.nav.features}</a>
        <a href="#plugins" role="listitem">{t.nav.plugins}</a>
        <a href="#security" role="listitem">{t.nav.security}</a>
      </div>

      <div class="nav-right">
        <div class="lang-switcher" role="group" aria-label="Language selector">
          {(['en', 'es', 'zh'] as Lang[]).map(l => (
            <a href={`/${l}/`} class={`lang-btn${l === lang ? ' active' : ''}`} aria-current={l === lang ? 'true' : undefined} lang={l}>
              {langLabels[l]}
            </a>
          ))}
        </div>
        <a href={GH_PROFILE} class="nav-github" target="_blank" rel="noopener" aria-label="Connectea on GitHub" title={oss.nav}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.31-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.87.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22 0 1.61-.01 2.9-.01 3.29 0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/></svg>
        </a>
        <button class="mobile-menu-btn" id="menuBtn" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
    <!-- Mobile menu -->
    <div class="mobile-menu" id="mobileMenu" role="menu">
      <a href="#features" role="menuitem">{t.nav.features}</a>
      <a href="#plugins" role="menuitem">{t.nav.plugins}</a>
      <a href="#security" role="menuitem">{t.nav.security}</a>
      <div class="mobile-lang">
        {(['en', 'es', 'zh'] as Lang[]).map(l => (
          <a href={`/${l}/`} class={`lang-btn${l === lang ? ' active' : ''}`} lang={l}>
            {langLabels[l]}
          </a>
        ))}
      </div>
      <a href={GH_PROFILE} class="btn btn-primary" target="_blank" rel="noopener">{oss.nav}</a>
    </div>
  </nav>

  <main id="main-content">

  <!-- ============ HERO ============ -->
  <section id="hero" aria-labelledby="hero-title">
    <div class="container hero-grid">
      <div class="hero-content" data-reveal>
        <div class="hero-badges">
          <div class="badge badge-primary"><span class="badge-dot" aria-hidden="true"></span>{t.hero.badge}</div>
          <div class="badge badge-green">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {t.hero.badge2}
          </div>
        </div>
        <h1 id="hero-title" class="hero-title">
          {lang === 'zh'
            ? <><span>{t.hero.headline.slice(0, -5)}</span><span class="gradient-text">{t.hero.headline.slice(-5)}</span></>
            : <><span>{t.hero.headline.split('.').slice(0, 2).join('.')+'.'}</span>{' '}<span class="gradient-text">{t.hero.headline.split('.').slice(2).join('.').trim()}</span></>
          }
        </h1>
        <p class="hero-subtitle">{t.hero.subheadline}</p>
        <div class="hero-actions">
          <a href={GH_PROFILE} class="btn btn-primary btn-lg" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.31-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.87.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22 0 1.61-.01 2.9-.01 3.29 0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/></svg>
            {oss.viewAll}
          </a>
          <a href="#plugins" class="btn btn-outline btn-lg">
            {t.hero.cta_secondary}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
        <div class="hero-stats" role="list">
          {t.hero.stats.map(stat => (
            <div class="stat" role="listitem">
              <div class="stat-value">{stat.value}</div>
              <div class="stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- App window mockup -->
      <div class="hero-visual" aria-hidden="true" data-reveal>
        <div class="app-window">
          <div class="app-titlebar">
            <div class="titlebar-dots">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <span class="titlebar-title">Connectea</span>
            <div style="width:52px"></div>
          </div>
          <div class="app-body">
            <div class="app-sidebar">
              <div class="sidebar-label">RECENT</div>
              <div class="room-item active">
                <span class="room-dot"></span>
                <span>mc-server</span>
              </div>
              <div class="room-item">
                <span class="room-dot dim"></span>
                <span>a0ff89ee</span>
              </div>
              <div class="room-item">
                <span class="room-dot dim"></span>
                <span>d5e76346</span>
              </div>
              <div class="room-add">+ Create Room</div>
            </div>
            <div class="app-main">
              <div class="app-header-bar">
                <span class="room-code-badge">mc-server</span>
                <span class="owner-badge">Owner</span>
              </div>
              <div class="file-list">
                <div class="file-row file-row-highlight">
                  <span class="file-icon">🎬</span>
                  <span class="file-name">project-final.mp4</span>
                  <span class="file-size">18.4 GB</span>
                  <span class="public-link-badge">🔗 Public</span>
                </div>
                <div class="file-row">
                  <span class="file-icon">📦</span>
                  <span class="file-name">backup-2026.zip</span>
                  <span class="file-size">7.1 GB</span>
                  <span class="enc-badge">🔒</span>
                </div>
                <div class="file-row">
                  <span class="file-icon">📁</span>
                  <span class="file-name">world/</span>
                  <span class="file-size">1.2 GB</span>
                  <span class="enc-badge">&nbsp;</span>
                </div>
                <div class="file-row">
                  <span class="file-icon">📄</span>
                  <span class="file-name">server.jar</span>
                  <span class="file-size">48 MB</span>
                  <span class="enc-badge">&nbsp;</span>
                </div>
              </div>
              <div class="mockup-storage-bar">
                <div class="mockup-storage-fill"></div>
                <span class="mockup-storage-text">26.8 GB subidos</span>
              </div>
              <div class="app-toolbar">
                <button class="tool-btn tool-btn-primary">↑ Upload</button>
                <button class="tool-btn tool-btn-ghost">↓ ZIP All</button>
                <button class="tool-btn tool-btn-active">🔌 Plugins ●</button>
              </div>
            </div>
          </div>
        </div>
        <div class="window-glow"></div>
        <div class="float-badge float-badge-tl" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          AES-256-GCM
        </div>
        <div class="float-badge float-badge-tr" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          No account
        </div>
        <div class="float-badge float-badge-br" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Public links
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PERMANENT ROOM ============ -->
  <section id="permanent-room" aria-labelledby="permanent-room-title">
    <div class="container">
      <div class="proom-inner" data-reveal>
        <div class="proom-content">
          <div class="badge badge-amber" style="margin-bottom:1.2rem">{t.permanentRoom.badge}</div>
          <h2 id="permanent-room-title" class="section-title">{t.permanentRoom.title}</h2>
          <p class="section-subtitle">{t.permanentRoom.subtitle}</p>
          <ul class="proom-bullets" role="list">
            {t.permanentRoom.bullets.map((b, i) => (
              <li role="listitem" class={i === t.permanentRoom.bullets.length - 1 ? 'proom-compare' : ''}>
                {i < t.permanentRoom.bullets.length - 1
                  ? <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  : <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                }
                {b}
              </li>
            ))}
          </ul>
          <a href="#opensource" class="btn btn-primary" style="margin-top:32px">{t.permanentRoom.cta}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SHARE HIGHLIGHT ============ -->
  <section id="share" aria-labelledby="share-title">
    <div class="container">
      <div class="share-hl-inner" data-reveal>
        <div class="badge badge-green" style="margin-bottom:1.1rem">{t.shareHighlight.eyebrow}</div>
        <h2 id="share-title" class="share-hl-title">{t.shareHighlight.title}</h2>
        <p class="share-hl-subtitle">{t.shareHighlight.subtitle}</p>
        <div class="share-hl-cards">
          <div class="share-hl-card">
            <div class="share-hl-icon" aria-hidden="true">{t.shareHighlight.card1.icon}</div>
            <h3 class="share-hl-card-title">{t.shareHighlight.card1.title}</h3>
            <p class="share-hl-card-desc">{t.shareHighlight.card1.desc}</p>
          </div>
          <div class="share-hl-card share-hl-card-accent">
            <div class="share-hl-icon" aria-hidden="true">{t.shareHighlight.card2.icon}</div>
            <h3 class="share-hl-card-title">{t.shareHighlight.card2.title}</h3>
            <p class="share-hl-card-desc">{t.shareHighlight.card2.desc}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FEATURES ============ -->
  <section id="features" aria-labelledby="features-title">
    <div class="container">
      <div class="section-header" data-reveal>
        <h2 id="features-title" class="section-title">{t.features.title}</h2>
        <p class="section-subtitle">{t.features.subtitle}</p>
      </div>
      <div class="features-grid">
        {t.features.items.map((item, i) => (
          <article class="feature-card" data-reveal style={`--delay: ${i * 0.08}s`}>
            <div class="feature-icon" aria-hidden="true">{item.icon}</div>
            <h3 class="feature-title">{item.title}</h3>
            <p class="feature-desc">{item.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section id="how" aria-labelledby="how-title">
    <div class="container">
      <div class="section-header" data-reveal>
        <h2 id="how-title" class="section-title">{t.howItWorks.title}</h2>
        <p class="section-subtitle">{t.howItWorks.subtitle}</p>
      </div>
      <div class="steps-grid">
        {t.howItWorks.steps.map((step, i) => (
          <div class="step" data-reveal style={`--delay: ${i * 0.12}s`}>
            <div class="step-num" aria-hidden="true">{step.number}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SECURITY ============ -->
  <section id="security" aria-labelledby="security-title">
    <div class="container">
      <div class="security-grid">
        <div class="security-content" data-reveal>
          <div class="badge badge-green">{t.security.badge}</div>
          <h2 id="security-title" class="section-title security-title">{t.security.title}</h2>
          <p class="section-subtitle">{t.security.subtitle}</p>
          <ul class="security-list" role="list">
            {t.security.points.map(point => (
              <li role="listitem">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {point}
              </li>
            ))}
          </ul>
        </div>
        <div class="security-visual" data-reveal>
          <div class="security-icon-wrap" aria-hidden="true">
            <div class="shield-outer">
              <div class="shield-inner">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
            </div>
          </div>
          <div class="crypto-label">AES-256-GCM</div>
          <div class="crypto-sub">Client-side encryption</div>
          <div class="crypto-badges">
            <span class="crypto-badge">PBKDF2</span>
            <span class="crypto-badge">SHA-256</span>
            <span class="crypto-badge">Zero-Knowledge</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PLUGINS ============ -->
  <section id="plugins" aria-labelledby="plugins-title">
    <div class="container">
      <div class="plugins-grid">
        <div class="plugins-content" data-reveal>
          <div class="badge badge-amber">{t.plugins.badge}</div>
          <h2 id="plugins-title" class="section-title">{t.plugins.title}</h2>
          <p class="section-subtitle">{t.plugins.subtitle}</p>
          <ul class="plugins-features" role="list">
            {t.plugins.features.map(feat => (
              <li role="listitem">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                {feat}
              </li>
            ))}
          </ul>
          <a href="#opensource" class="btn btn-primary" style="margin-top: 32px;">{t.plugins.cta}</a>
        </div>
        <div class="plugin-terminal" data-reveal aria-hidden="true">
          <div class="terminal-header">
            <div class="titlebar-dots">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <span class="terminal-title">Minecraft Server</span>
            <div style="width:52px"></div>
          </div>
          <div class="terminal-body">
            <div><span class="t-muted">$</span> <span class="t-blue">connectea</span> plugin start minecraft-server</div>
            <div><span class="t-green">✓</span> World files loaded from room</div>
            <div><span class="t-amber">→</span> Starting server on :25565...</div>
            <div class="t-muted">&nbsp;&nbsp;[████████████████] 100%</div>
            <div><span class="t-green">✓</span> Server online · 0/20 players</div>
            <div><span class="t-amber">→</span> Player <span class="t-blue">Alex</span> joined the game</div>
            <div><span class="t-amber">→</span> Player <span class="t-blue">Steve</span> joined the game</div>
            <div><span class="t-green">✓</span> 2/20 players online</div>
            <div><span class="t-muted">$</span> <span class="cursor"></span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ OPEN SOURCE ============ -->
  <section id="opensource" aria-labelledby="opensource-title">
    <div class="container">
      <div class="os-inner" data-reveal>
        <div class="os-glow" aria-hidden="true"></div>
        <div class="badge badge-primary os-badge">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.31-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.87.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22 0 1.61-.01 2.9-.01 3.29 0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/></svg>
          {oss.badge}
        </div>
        <h2 id="opensource-title" class="section-title os-title">{oss.title}</h2>
        <p class="section-subtitle os-subtitle">{oss.subtitle}</p>
        <div class="os-repos">
          <a href={GH_REPOS.app} class="os-repo" target="_blank" rel="noopener"><span class="os-repo-icon" aria-hidden="true">🖥️</span><span>connectea</span><small>{oss.repos.app}</small></a>
          <a href={GH_REPOS.backend} class="os-repo" target="_blank" rel="noopener"><span class="os-repo-icon" aria-hidden="true">⚙️</span><span>connectea-backend</span><small>{oss.repos.backend}</small></a>
          <a href={GH_REPOS.velocity} class="os-repo" target="_blank" rel="noopener"><span class="os-repo-icon" aria-hidden="true">🔀</span><span>connectea-velocity</span><small>{oss.repos.velocity}</small></a>
          <a href={GH_REPOS.web} class="os-repo" target="_blank" rel="noopener"><span class="os-repo-icon" aria-hidden="true">🌐</span><span>connectea-web</span><small>{oss.repos.web}</small></a>
        </div>
        <a href={GH_PROFILE} class="btn btn-primary os-cta" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.31-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.87.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22 0 1.61-.01 2.9-.01 3.29 0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/></svg>
          {oss.viewAll}
        </a>
      </div>
    </div>
  </section>

  </main>

  <!-- ============ DOMAIN FOR SALE OVERLAY ============ -->
  <!-- Shown once per session on entry — connectea.net domain is for sale -->
  <div id="for-sale-overlay" class="rjo-backdrop" hidden aria-modal="true" role="dialog" aria-labelledby="fs-title">
    <div class="rjo-card">
      <div class="rjo-glow" aria-hidden="true"></div>

      <div class="rjo-logo" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
          <line x1="7" y1="7" x2="7.01" y2="7"/>
        </svg>
      </div>

      <p class="rjo-eyebrow" id="fs-eyebrow"></p>
      <h2 class="rjo-title" id="fs-title"></h2>
      <p class="fs-body" id="fs-body"></p>

      <div class="rjo-room-badge" style="font-family:var(--font)">connectea.net</div>

      <a id="fs-contact-btn" class="rjo-btn rjo-btn-primary" href="mailto:contact@connectea.net">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
        </svg>
        <span id="fs-contact-text"></span>
      </a>

      <button id="fs-dismiss-btn" class="rjo-btn rjo-btn-secondary" type="button"><span id="fs-dismiss-text"></span></button>

      <button class="rjo-dismiss" id="fs-close-btn" aria-label="Dismiss">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- ============ FOOTER ============ -->
  <footer role="contentinfo">
    <div class="container">
      <div class="footer-top">
        <div class="footer-brand">
          <a href={`/${lang}/`} class="logo footer-logo" aria-label="Connectea home">
            <div class="logo-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 32 32" fill="none">
                <circle cx="10" cy="16" r="4" fill="white"/>
                <circle cx="24" cy="9" r="3" fill="white" opacity="0.85"/>
                <circle cx="24" cy="23" r="3" fill="white" opacity="0.85"/>
                <line x1="10" y1="16" x2="24" y2="9" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
                <line x1="10" y1="16" x2="24" y2="23" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
              </svg>
            </div>
            <span>Connectea</span>
          </a>
          <p class="footer-tagline">{t.footer.tagline}</p>
        </div>

        <div class="footer-links-col">
          <h4 class="footer-links-title">{t.footer.product}</h4>
          <ul class="footer-links" role="list">
            <li><a href="#features">{t.footer.links.features}</a></li>
            <li><a href="#security">{t.footer.links.security}</a></li>
            <li><a href="#opensource">{oss.footerCol}</a></li>
          </ul>
        </div>

        <div class="footer-links-col">
          <h4 class="footer-links-title">{t.footer.legal}</h4>
          <ul class="footer-links" role="list">
            <li><a href={`/${lang}/privacy/`}>{t.footer.links.privacyPolicy}</a></li>
            <li><a href={`/${lang}/terms/`}>{t.footer.links.terms}</a></li>
            <li><a href={`/${lang}/about/`}>{t.footer.links.about}</a></li>
            <li><a href="mailto:contact@connectea.net">{t.footer.links.contact}</a></li>
            <li><a href="mailto:bug-report@connectea.net?subject=Bug%20Report%20-%20Connectea">{t.footer.links.privacy}</a></li>
          </ul>
        </div>

        <div class="footer-links-col">
          <h4 class="footer-links-title">{oss.footerCol}</h4>
          <ul class="footer-links" role="list">
            <li><a href={GH_REPOS.app} target="_blank" rel="noopener">connectea</a></li>
            <li><a href={GH_REPOS.backend} target="_blank" rel="noopener">connectea-backend</a></li>
            <li><a href={GH_REPOS.velocity} target="_blank" rel="noopener">connectea-velocity</a></li>
            <li><a href={GH_REPOS.web} target="_blank" rel="noopener">connectea-web</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-bottom">
        <p class="footer-copy">{t.footer.copyright}</p>
        <div class="footer-lang" role="group" aria-label="Language selector">
          {(['en', 'es', 'zh'] as Lang[]).map(l => (
            <a href={`/${l}/`} class={`lang-btn${l === lang ? ' active' : ''}`} lang={l}>
              {langLabels[l]}
            </a>
          ))}
        </div>
      </div>
    </div>
  </footer>

</body>
</html>

<style is:global>
  /* ===== VARIABLES ===== */
  :root {
    --bg: #09090f;
    --bg-surface: #0f0f1a;
    --bg-card: rgba(255, 255, 255, 0.035);
    --bg-card-hover: rgba(255, 255, 255, 0.06);
    --border: rgba(99, 102, 241, 0.25);
    --border-subtle: rgba(255, 255, 255, 0.07);

    --primary: #6366f1;
    --primary-light: #818cf8;
    --primary-dark: #4f46e5;
    --gradient: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    --gradient-text: linear-gradient(135deg, #a5b4fc 0%, #c084fc 100%);

    --text: #f1f5f9;
    --text-secondary: #94a3b8;
    --text-muted: #475569;

    --green: #22c55e;
    --green-light: #4ade80;
    --amber: #f59e0b;
    --red: #ef4444;

    --radius-sm: 8px;
    --radius: 12px;
    --radius-lg: 18px;
    --radius-xl: 24px;

    --shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    --shadow-glow: 0 0 48px rgba(99, 102, 241, 0.15);

    --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-display: 'Space Grotesk', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --container: 1200px;

    --teal: #22d3ee;
    --teal-light: #67e8f9;
  }

  /* ===== RESET ===== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; font-size: 16px; }
  body { background: var(--bg); color: var(--text); font-family: var(--font); line-height: 1.6; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
  a { text-decoration: none; color: inherit; }
  img, svg { display: block; }
  button { cursor: pointer; border: none; background: none; font-family: inherit; }
  ul { list-style: none; }

  /* ===== ACCESSIBILITY ===== */
  :focus-visible { outline: 2px solid var(--primary-light); outline-offset: 3px; border-radius: 4px; }
  .skip-link { position: absolute; top: -100%; left: 16px; z-index: 999; background: var(--primary); color: white; padding: 8px 16px; border-radius: var(--radius-sm); font-weight: 600; font-size: 0.9rem; transition: top 0.2s; }
  .skip-link:focus { top: 8px; }

  /* ===== UTILS ===== */
  .container { max-width: var(--container); margin: 0 auto; padding: 0 24px; }
  .gradient-text { background: var(--gradient-text); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
  .section-header { text-align: center; max-width: 640px; margin: 0 auto 64px; }
  .section-title { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 16px; font-family: var(--font-display); }
  .section-subtitle { font-size: 1.1rem; color: var(--text-secondary); line-height: 1.7; }
  .section-title::after {
    content: '';
    display: block;
    width: 60px; height: 3px;
    background: var(--gradient);
    border-radius: 2px;
    margin: 12px 0 0;
    box-shadow: 0 0 14px rgba(99,102,241,0.65);
  }
  .section-header .section-title::after {
    margin: 12px auto 0;
  }
  .security-content .section-title::after {
    background: linear-gradient(135deg, var(--green-light), var(--teal));
    box-shadow: 0 0 10px rgba(34,197,94,0.45);
  }
  .plugins-content .section-title::after {
    background: linear-gradient(135deg, var(--amber), #fbbf24);
    box-shadow: 0 0 10px rgba(245,158,11,0.45);
  }

  /* ===== BADGES ===== */
  .badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 14px; border-radius: 100px;
    font-size: 0.75rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    width: fit-content; margin-bottom: 20px;
  }
  .badge-primary { background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.35); color: var(--primary-light); }
  .badge-green { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: var(--green-light); }
  .badge-amber { background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.3); color: #fbbf24; }
  .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; animation: badgePulse 2.5s ease-in-out infinite; }
  @keyframes badgePulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 22px; border-radius: var(--radius-sm);
    font-weight: 600; font-size: 0.95rem; font-family: var(--font);
    transition: all 0.2s ease; white-space: nowrap; cursor: pointer;
  }
  .btn-primary { background: var(--gradient); color: white; border: 1px solid transparent; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(99,102,241,0.45); }
  .btn-outline { background: transparent; color: var(--text); border: 1px solid var(--border-subtle); }
  .btn-outline:hover { background: var(--bg-card-hover); border-color: var(--border); transform: translateY(-1px); }
  .btn-lg { padding: 14px 28px; font-size: 1rem; border-radius: var(--radius); }
  .btn-full { width: 100%; justify-content: center; }

  /* ===== BACKGROUND DECORATION ===== */
  .bg-deco { position: fixed; inset: 0; pointer-events: none; overflow: hidden; z-index: 0; }
  .blob { position: absolute; border-radius: 50%; filter: blur(90px); opacity: 0.12; will-change: transform; }
  .blob-1 { width: 700px; height: 700px; background: #6366f1; top: -250px; left: -150px; animation: blobMove 10s ease-in-out infinite; }
  .blob-2 { width: 550px; height: 550px; background: #8b5cf6; bottom: 50px; right: -200px; animation: blobMove 13s ease-in-out infinite reverse; }
  .blob-3 { width: 450px; height: 450px; background: #0ea5e9; top: 40%; left: 30%; animation: blobMove 8s ease-in-out infinite 3s; opacity: 0.07; }
  @keyframes blobMove {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(25px, -20px) scale(1.05); }
    66% { transform: translate(-15px, 15px) scale(0.95); }
  }
  .bg-deco::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  /* ===== SCROLL REVEAL ===== */
  [data-reveal] { opacity: 0; transform: translateY(24px); transition: opacity 0.65s ease calc(var(--delay, 0s)), transform 0.65s ease calc(var(--delay, 0s)); }
  [data-reveal].revealed { opacity: 1; transform: translateY(0); }

  /* ===== NAVIGATION ===== */
  #nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    padding: 14px 0;
    backdrop-filter: blur(24px) saturate(1.5);
    background: rgba(9, 9, 15, 0.7);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, background 0.3s;
  }
  #nav.scrolled { background: rgba(9, 9, 15, 0.92); border-bottom-color: var(--border-subtle); }
  .nav-inner { display: flex; align-items: center; gap: 16px; }
  .logo { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 1.15rem; letter-spacing: -0.01em; }
  .logo-icon { width: 34px; height: 34px; background: var(--gradient); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .nav-links { display: flex; gap: 4px; margin: 0 auto; }
  .nav-links a { padding: 7px 16px; border-radius: var(--radius-sm); font-size: 0.9rem; color: var(--text-secondary); transition: all 0.2s; }
  .nav-links a:hover { color: var(--text); background: var(--bg-card); }
  .nav-right { display: flex; align-items: center; gap: 12px; }
  .lang-switcher { display: flex; background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); overflow: hidden; }
  .lang-btn { padding: 6px 11px; font-size: 0.78rem; font-weight: 600; color: var(--text-muted); transition: all 0.2s; }
  .lang-btn:hover { color: var(--text); }
  .lang-btn.active { background: var(--primary); color: white; }
  .nav-cta { font-size: 0.88rem; padding: 9px 18px; }
  .mobile-menu-btn { display: none; flex-direction: column; gap: 5px; padding: 4px; }
  .mobile-menu-btn span { display: block; width: 22px; height: 2px; background: var(--text-secondary); border-radius: 2px; transition: all 0.2s; }
  .mobile-menu { display: none; }

  /* ===== HERO ===== */
  #hero {
    min-height: 100vh; display: flex; align-items: center;
    padding: 120px 0 80px; position: relative; z-index: 1;
  }
  .hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
  .hero-content { position: relative; }
  .hero-title { font-size: clamp(2.4rem, 5vw, 3.6rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 20px; font-family: var(--font-display); }
  .hero-subtitle { font-size: 1.15rem; color: var(--text-secondary); line-height: 1.75; margin-bottom: 36px; max-width: 500px; }
  .hero-badges { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 22px; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 14px; margin-bottom: 16px; }
  .hero-minecraft-link { margin-bottom: 36px; }
  .hero-minecraft-link a { font-size: 0.875rem; color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
  .hero-minecraft-link a:hover { color: var(--text-secondary); }
  .hero-stats { display: flex; gap: 36px; }
  .stat { position: relative; }
  .stat:not(:last-child)::after { content: ''; position: absolute; right: -18px; top: 50%; transform: translateY(-50%); width: 1px; height: 28px; background: rgba(255,255,255,0.12); }
  .stat-value { font-size: 1.6rem; font-weight: 800; background: var(--gradient-text); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 3px; letter-spacing: -0.02em; }
  .stat-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }

  /* ===== APP WINDOW MOCKUP ===== */
  .hero-visual { position: relative; }
  .window-glow {
    position: absolute; inset: -32px; z-index: -1;
    background: radial-gradient(ellipse at center, rgba(99,102,241,0.28) 0%, transparent 70%);
    border-radius: 48px;
    animation: glowPulse 5s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }
  .app-window {
    background: #0d0d1a;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px; overflow: hidden;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(99,102,241,0.22);
    transform: perspective(1200px) rotateY(-6deg) rotateX(3deg);
    transition: transform 0.6s ease;
    animation: float 7s ease-in-out infinite;
  }
  .app-window:hover { transform: perspective(1200px) rotateY(0deg) rotateX(0deg); animation-play-state: paused; }
  @keyframes float {
    0%, 100% { transform: perspective(1200px) rotateY(-6deg) rotateX(3deg) translateY(0); }
    50% { transform: perspective(1200px) rotateY(-6deg) rotateX(3deg) translateY(-10px); }
  }
  .app-titlebar {
    display: flex; align-items: center; padding: 11px 14px;
    background: #070710; border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .titlebar-dots { display: flex; gap: 7px; }
  .dot { width: 12px; height: 12px; border-radius: 50%; }
  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }
  .titlebar-title { margin: 0 auto; font-size: 0.72rem; color: var(--text-muted); letter-spacing: 0.08em; font-weight: 500; }
  .app-body { display: flex; height: 300px; }
  .app-sidebar {
    width: 160px; background: #08080f; padding: 12px 10px;
    border-right: 1px solid rgba(255,255,255,0.05);
    display: flex; flex-direction: column; gap: 2px;
  }
  .sidebar-label { font-size: 0.62rem; font-weight: 600; color: var(--text-muted); letter-spacing: 0.1em; padding: 0 6px 8px; }
  .room-item {
    padding: 7px 8px; border-radius: 7px; font-size: 0.72rem; font-weight: 500;
    display: flex; align-items: center; gap: 7px; color: var(--text-secondary);
    font-family: monospace; transition: all 0.15s;
  }
  .room-item.active { background: rgba(99,102,241,0.15); color: var(--primary-light); }
  .room-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); flex-shrink: 0; }
  .room-dot.dim { background: var(--text-muted); }
  .room-add { padding: 7px 8px; font-size: 0.7rem; color: var(--text-muted); cursor: pointer; margin-top: 4px; }
  .app-main { flex: 1; padding: 12px; display: flex; flex-direction: column; gap: 8px; overflow: hidden; }
  .app-header-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
  .room-code-badge { font-size: 0.68rem; font-weight: 600; font-family: monospace; background: rgba(99,102,241,0.12); color: var(--primary-light); padding: 3px 8px; border-radius: 5px; }
  .owner-badge { font-size: 0.62rem; font-weight: 600; background: rgba(245,158,11,0.12); color: #fbbf24; padding: 3px 7px; border-radius: 5px; }
  .file-list { flex: 1; display: flex; flex-direction: column; gap: 4px; }
  .file-row {
    display: flex; align-items: center; gap: 8px; padding: 6px 8px;
    background: rgba(255,255,255,0.025); border-radius: 7px;
    border: 1px solid rgba(255,255,255,0.04); font-size: 0.71rem;
    transition: background 0.15s;
  }
  .file-row:hover { background: rgba(255,255,255,0.045); }
  .file-icon { font-size: 0.9rem; }
  .file-name { color: var(--text-secondary); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .file-size { color: var(--text-muted); font-size: 0.65rem; flex-shrink: 0; }
  .enc-badge { font-size: 0.7rem; flex-shrink: 0; width: 16px; text-align: center; }
  .file-row-highlight { border-color: rgba(52,211,153,0.18) !important; background: rgba(52,211,153,0.04) !important; }
  .public-link-badge {
    font-size: 0.6rem; font-weight: 700; flex-shrink: 0;
    padding: 1px 5px; border-radius: 4px;
    background: rgba(52,211,153,0.15); color: #34d399;
    border: 1px solid rgba(52,211,153,0.3);
    white-space: nowrap;
  }
  .mockup-storage-bar {
    display: flex; align-items: center; gap: 7px; margin: 6px 0 2px;
  }
  .mockup-storage-fill {
    flex: 1; height: 3px; border-radius: 2px;
    background: linear-gradient(90deg, #6366f1 0%, #6366f1 53.6%, rgba(255,255,255,0.08) 53.6%);
  }
  .mockup-storage-text { font-size: 0.6rem; color: var(--text-muted); flex-shrink: 0; }
  .app-toolbar {
    display: flex; gap: 6px; padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .tool-btn { padding: 5px 10px; border-radius: 6px; font-size: 0.68rem; font-weight: 500; transition: all 0.15s; }
  .tool-btn-primary { background: var(--gradient); color: white; }
  .tool-btn-ghost { background: rgba(255,255,255,0.04); color: var(--text-secondary); border: 1px solid rgba(255,255,255,0.06); }
  .tool-btn-ghost:hover { background: rgba(255,255,255,0.07); }
  .tool-btn-active { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.3); }

  /* ===== PERMANENT ROOM ===== */
  #permanent-room { padding: 80px 0; position: relative; z-index: 1; }
  .proom-inner { max-width: 720px; margin: 0 auto; }
  .proom-content { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 48px; }
  .proom-bullets { list-style: none; padding: 0; margin: 28px 0 0; display: flex; flex-direction: column; gap: 14px; }
  .proom-bullets li { display: flex; align-items: flex-start; gap: 10px; font-size: 0.95rem; color: var(--text-secondary); }
  .proom-bullets li svg { flex-shrink: 0; margin-top: 3px; color: var(--green); }
  .proom-compare { border-top: 1px solid var(--border-subtle); padding-top: 14px; margin-top: 4px; font-size: 0.85rem !important; color: var(--text-muted) !important; }
  .proom-compare svg { color: var(--text-muted) !important; }
  @media (max-width: 640px) { .proom-content { padding: 28px 20px; } }

  /* ===== SHARE HIGHLIGHT ===== */
  #share { padding: 80px 0; position: relative; z-index: 1; }
  .share-hl-inner { text-align: center; }
  .share-hl-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.15;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }
  .share-hl-subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .share-hl-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 860px;
    margin: 0 auto;
  }
  .share-hl-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    text-align: left;
    transition: border-color 0.2s, transform 0.2s;
  }
  .share-hl-card:hover { border-color: rgba(52,211,153,0.3); transform: translateY(-3px); }
  .share-hl-card-accent {
    border-color: rgba(52,211,153,0.2);
    background: linear-gradient(135deg, rgba(52,211,153,0.06), rgba(16,185,129,0.03));
  }
  .share-hl-card-accent:hover { border-color: rgba(52,211,153,0.45); }
  .share-hl-icon { font-size: 2.4rem; margin-bottom: 1rem; display: block; }
  .share-hl-card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.6rem;
  }
  .share-hl-card-desc {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* ===== FEATURES ===== */
  #features { padding: 100px 0; position: relative; z-index: 1; }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 28px; transition: all 0.3s ease;
    position: relative; overflow: hidden;
  }
  .feature-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--primary), var(--primary-light), transparent);
    opacity: 0; transition: opacity 0.3s;
  }
  .feature-card:nth-child(3n+2)::before {
    background: linear-gradient(90deg, transparent, var(--teal), var(--teal-light), transparent);
  }
  .feature-card:nth-child(3n)::before {
    background: linear-gradient(90deg, transparent, var(--green), var(--green-light), transparent);
  }
  .feature-card:hover {
    border-color: var(--border);
    transform: translateY(-5px);
    box-shadow: var(--shadow), var(--shadow-glow);
    background: var(--bg-card-hover);
  }
  .feature-card:nth-child(3n+2):hover { box-shadow: var(--shadow), 0 0 48px rgba(34,211,238,0.13); }
  .feature-card:nth-child(3n):hover { box-shadow: var(--shadow), 0 0 48px rgba(34,197,94,0.13); }
  .feature-card:hover::before { opacity: 1; }
  .feature-icon {
    font-size: 1.75rem; margin-bottom: 18px;
    width: 54px; height: 54px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.22);
    border-radius: var(--radius); transition: all 0.3s;
    box-shadow: 0 2px 12px rgba(99,102,241,0.1);
  }
  .feature-card:hover .feature-icon { background: rgba(99,102,241,0.2); border-color: rgba(99,102,241,0.4); transform: scale(1.1); box-shadow: 0 0 24px rgba(99,102,241,0.28); }
  .feature-card:nth-child(3n+2) .feature-icon { background: rgba(34,211,238,0.1); border-color: rgba(34,211,238,0.2); box-shadow: 0 2px 12px rgba(34,211,238,0.08); }
  .feature-card:nth-child(3n) .feature-icon { background: rgba(34,197,94,0.1); border-color: rgba(34,197,94,0.2); box-shadow: 0 2px 12px rgba(34,197,94,0.08); }
  .feature-card:nth-child(3n+2):hover .feature-icon { background: rgba(34,211,238,0.2); border-color: rgba(34,211,238,0.4); box-shadow: 0 0 24px rgba(34,211,238,0.28); }
  .feature-card:nth-child(3n):hover .feature-icon { background: rgba(34,197,94,0.2); border-color: rgba(34,197,94,0.35); box-shadow: 0 0 24px rgba(34,197,94,0.25); }
  .feature-title { font-size: 1.05rem; font-weight: 700; margin-bottom: 10px; }
  .feature-desc { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.65; }

  /* ===== HOW IT WORKS ===== */
  #how {
    padding: 100px 0; position: relative; z-index: 1;
    background: linear-gradient(180deg, transparent, rgba(99,102,241,0.03), transparent);
  }
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; position: relative; }
  .steps-grid::before {
    content: ''; position: absolute;
    top: 40px; left: 16.6%; width: 66.8%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--primary), transparent);
  }
  .step { text-align: center; padding: 0 16px; }
  .step-num {
    display: flex; align-items: center; justify-content: center;
    width: 80px; height: 80px; border-radius: 50%;
    background: var(--gradient);
    font-size: 1.25rem; font-weight: 800; color: white;
    margin: 0 auto 24px; position: relative; z-index: 1;
    box-shadow: 0 8px 28px rgba(99,102,241,0.45), 0 0 0 8px rgba(99,102,241,0.1), 0 0 0 16px rgba(99,102,241,0.04);
    font-family: var(--font-display);
  }
  .step-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 12px; }
  .step-desc { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.65; }

  /* ===== SECURITY ===== */
  #security {
    padding: 100px 0; position: relative; z-index: 1;
    background: linear-gradient(135deg, rgba(99,102,241,0.04), rgba(34,197,94,0.03));
    border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle);
  }
  .security-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .security-title { margin-bottom: 14px; }
  .security-list { display: flex; flex-direction: column; gap: 14px; margin-top: 28px; }
  .security-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.5; }
  .security-list li svg { color: var(--green-light); flex-shrink: 0; margin-top: 3px; }
  .security-visual {
    background: var(--bg-card); border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl); padding: 52px 40px; text-align: center;
    position: relative; overflow: hidden;
  }
  .security-visual::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 30%, rgba(34,197,94,0.1) 0%, transparent 70%);
  }
  .shield-outer {
    width: 120px; height: 120px; margin: 0 auto 28px;
    background: linear-gradient(135deg, rgba(34,197,94,0.15), rgba(34,197,94,0.05));
    border: 1px solid rgba(34,197,94,0.25);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    position: relative; z-index: 1;
    animation: shieldPulse 3.5s ease-in-out infinite;
  }
  @keyframes shieldPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.15); }
    50% { box-shadow: 0 0 0 18px rgba(34,197,94,0); }
  }
  .shield-inner {
    width: 80px; height: 80px;
    background: linear-gradient(135deg, rgba(34,197,94,0.2), rgba(34,197,94,0.08));
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
  }
  .shield-inner svg { color: var(--green-light); }
  .crypto-label {
    font-size: 1.1rem; font-weight: 800; letter-spacing: 0.08em;
    background: linear-gradient(135deg, var(--green-light), #22d3ee);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    margin-bottom: 6px; position: relative; z-index: 1;
  }
  .crypto-sub { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 20px; position: relative; z-index: 1; }
  .crypto-badges { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; position: relative; z-index: 1; }
  .crypto-badge {
    font-size: 0.72rem; font-weight: 600; font-family: monospace;
    padding: 4px 10px; border-radius: 6px;
    background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2);
    color: var(--green-light);
  }

  /* ===== PLUGINS ===== */
  #plugins { padding: 100px 0; position: relative; z-index: 1; background: linear-gradient(180deg, transparent, rgba(245,158,11,0.025), transparent); }
  .plugins-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .plugins-features { display: flex; flex-direction: column; gap: 14px; margin-top: 24px; }
  .plugins-features li { display: flex; align-items: flex-start; gap: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.5; }
  .plugins-features li svg { color: var(--primary-light); flex-shrink: 0; margin-top: 3px; }
  .plugin-terminal { background: #07070e; border: 1px solid rgba(255,255,255,0.1); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); }
  .terminal-header {
    display: flex; align-items: center; padding: 11px 14px;
    background: #050509; border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .terminal-title { margin: 0 auto; font-size: 0.72rem; color: var(--text-muted); font-weight: 500; }
  .terminal-body { padding: 20px 20px 24px; font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace; font-size: 0.8rem; line-height: 2; color: #64748b; }
  .t-green { color: var(--green-light); }
  .t-blue { color: #60a5fa; }
  .t-amber { color: #fbbf24; }
  .t-muted { color: #334155; }
  .cursor { display: inline-block; width: 8px; height: 15px; background: var(--primary); border-radius: 1px; animation: blink 1.1s step-end infinite; vertical-align: text-bottom; }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* ===== FOOTER ===== */
  footer { padding: 64px 0 32px; border-top: 1px solid var(--border-subtle); position: relative; z-index: 1; }
  .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 64px; margin-bottom: 48px; }
  .footer-brand .logo { margin-bottom: 14px; }
  .footer-logo { display: inline-flex; }
  .footer-tagline { font-size: 0.9rem; color: var(--text-muted); max-width: 280px; line-height: 1.65; }
  .footer-links-title { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-secondary); margin-bottom: 18px; }
  .footer-links { display: flex; flex-direction: column; gap: 10px; }
  .footer-links li a { font-size: 0.9rem; color: var(--text-muted); transition: color 0.2s; }
  .footer-links li a:hover { color: var(--text); }
  .footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 24px; border-top: 1px solid var(--border-subtle); }
  .footer-copy { font-size: 0.85rem; color: var(--text-muted); }
  .footer-lang { display: flex; background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); overflow: hidden; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 60px; }
    .hero-content { text-align: center; }
    .hero-subtitle { margin-left: auto; margin-right: auto; }
    .hero-actions { justify-content: center; }
    .hero-stats { justify-content: center; }
    .hero-visual { max-width: 600px; margin: 0 auto; }
    .security-grid, .plugins-grid { grid-template-columns: 1fr; gap: 48px; }
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .share-hl-cards { gap: 16px; }
    .footer-top { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-cta { display: none; }
    .mobile-menu-btn { display: flex; }
    .mobile-menu.open {
      display: flex; flex-direction: column; gap: 8px;
      padding: 16px 24px; border-top: 1px solid var(--border-subtle);
      background: rgba(9,9,15,0.98);
    }
    .mobile-menu a { padding: 10px 14px; border-radius: var(--radius-sm); color: var(--text-secondary); font-size: 0.95rem; }
    .mobile-menu a:hover { background: var(--bg-card); color: var(--text); }
    .mobile-lang { display: flex; gap: 8px; padding: 6px 0; }
    .mobile-menu .btn { justify-content: center; margin-top: 8px; }
    .hero-title { font-size: clamp(2rem, 7vw, 3rem); }
    .hero-stats { flex-wrap: wrap; gap: 24px; }
    .stat::after { display: none; }
    .features-grid { grid-template-columns: 1fr; }
    .share-hl-cards { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: 1fr; gap: 40px; }
    .steps-grid::before { display: none; }
    .footer-top { grid-template-columns: 1fr; gap: 36px; }
    .footer-bottom { flex-direction: column; gap: 16px; }
    #features, #how, #security, #plugins, #opensource { padding: 64px 0; }
  }

  @media (max-width: 480px) {
    .hero-actions { flex-direction: column; }
    .btn-lg { width: 100%; justify-content: center; }
    .app-window { transform: none; animation: none; }
  }

  /* ===== NAV GITHUB ===== */
  .nav-github {
    display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; border-radius: var(--radius-sm);
    color: var(--text-secondary); border: 1px solid var(--border-subtle);
    transition: all 0.2s ease;
  }
  .nav-github:hover { color: var(--text); background: var(--bg-card-hover); border-color: var(--border); transform: translateY(-1px); }

  /* ===== OPEN SOURCE ===== */
  #opensource { padding: 96px 0; }
  .os-inner {
    position: relative; overflow: hidden;
    text-align: center; max-width: 880px; margin: 0 auto;
    padding: 56px 40px;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-xl); box-shadow: var(--shadow-glow);
  }
  .os-glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse at 50% 0%, rgba(99,102,241,0.16) 0%, transparent 60%);
  }
  .os-badge { margin: 0 auto 20px; }
  .os-title { position: relative; }
  .os-title::after { margin: 12px auto 0; }
  .os-subtitle { position: relative; max-width: 620px; margin: 0 auto 36px; color: var(--text-secondary); }
  .os-repos {
    position: relative;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;
    max-width: 600px; margin: 0 auto 32px; text-align: left;
  }
  .os-repo {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    padding: 14px 16px; border-radius: var(--radius);
    background: rgba(255,255,255,0.03); border: 1px solid var(--border-subtle);
    font-weight: 600; font-size: 0.92rem; transition: all 0.2s ease;
  }
  .os-repo:hover { background: var(--bg-card-hover); border-color: var(--border); transform: translateY(-2px); }
  .os-repo-icon { font-size: 1.05rem; }
  .os-repo small { width: 100%; color: var(--text-muted); font-weight: 500; font-size: 0.78rem; }
  .os-cta { position: relative; margin-top: 4px; }
  @media (max-width: 600px) {
    .os-inner { padding: 40px 22px; }
    .os-repos { grid-template-columns: 1fr; }
    #opensource { padding: 64px 0; }
  }

  /* ===== FOR SALE OVERLAY ===== */
  .fs-body {
    font-size: 0.95rem; color: var(--text-secondary); line-height: 1.6;
    margin-bottom: 20px;
  }

  /* ===== ROOM JOIN OVERLAY ===== */
  .rjo-backdrop {
    position: fixed; inset: 0; z-index: 500;
    background: rgba(9, 9, 15, 0.85);
    backdrop-filter: blur(12px) saturate(1.4);
    display: flex; align-items: center; justify-content: center;
    padding: 24px;
    animation: rjo-fade-in 0.25s ease;
  }
  .rjo-backdrop[hidden] { display: none; }

  @keyframes rjo-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .rjo-card {
    position: relative;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 40px 36px 32px;
    max-width: 420px;
    width: 100%;
    text-align: center;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6), var(--shadow-glow);
    animation: rjo-slide-up 0.3s ease;
  }

  @keyframes rjo-slide-up {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .rjo-glow {
    position: absolute; inset: 0; border-radius: inherit; pointer-events: none;
    background: radial-gradient(ellipse at 50% 0%, rgba(99,102,241,0.18) 0%, transparent 65%);
  }

  .rjo-logo {
    width: 56px; height: 56px;
    background: var(--gradient);
    border-radius: var(--radius);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
    box-shadow: 0 8px 24px rgba(99,102,241,0.4);
  }

  .rjo-eyebrow {
    font-size: 0.72rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--primary-light); margin-bottom: 8px;
  }

  .rjo-title {
    font-size: 1.4rem; font-weight: 800; letter-spacing: -0.02em;
    line-height: 1.2; margin-bottom: 16px;
  }

  .rjo-room-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.3);
    border-radius: 8px; padding: 6px 14px; margin-bottom: 24px;
    font-size: 0.82rem; font-weight: 600; font-family: monospace;
    color: var(--primary-light);
  }

  .rjo-btn {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; padding: 12px 20px; border-radius: var(--radius-sm);
    font-size: 0.95rem; font-weight: 600; font-family: var(--font);
    cursor: pointer; border: none; transition: all 0.2s ease;
    text-decoration: none; margin-bottom: 10px;
  }
  .rjo-btn-primary {
    background: var(--gradient); color: white;
  }
  .rjo-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(99,102,241,0.45); }

  .rjo-btn-secondary {
    background: transparent; color: var(--text-secondary);
    border: 1px solid var(--border-subtle) !important;
  }
  .rjo-btn-secondary:hover { background: var(--bg-card-hover); color: var(--text); }

  .rjo-dismiss {
    position: absolute; top: 14px; right: 14px;
    background: transparent; border: none; cursor: pointer;
    color: var(--text-muted); padding: 6px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s, color 0.15s;
  }
  .rjo-dismiss:hover { background: var(--bg-card); color: var(--text); }

  /* ===== FLOATING HERO BADGES ===== */
  .float-badge {
    position: absolute;
    display: inline-flex; align-items: center; gap: 7px;
    padding: 7px 13px; border-radius: 100px;
    font-size: 0.72rem; font-weight: 600;
    backdrop-filter: blur(16px) saturate(1.4);
    white-space: nowrap; pointer-events: none; z-index: 10;
    box-shadow: 0 4px 20px rgba(0,0,0,0.45), 0 1px 0 rgba(255,255,255,0.06) inset;
  }
  .float-badge svg { flex-shrink: 0; }
  .float-badge-tl {
    top: -14px; left: 18px;
    background: rgba(99,102,241,0.15); border: 1px solid rgba(99,102,241,0.3);
    color: var(--primary-light);
    animation: floatBadge 5s ease-in-out infinite;
  }
  .float-badge-tr {
    top: 70px; right: -18px;
    background: rgba(34,211,238,0.1); border: 1px solid rgba(34,211,238,0.25);
    color: var(--teal-light);
    animation: floatBadge 6.5s ease-in-out infinite 0.9s;
  }
  .float-badge-br {
    bottom: 80px; right: -18px;
    background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.25);
    color: var(--green-light);
    animation: floatBadge 7s ease-in-out infinite 1.8s;
  }
  @keyframes floatBadge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-7px); }
  }
  @media (max-width: 900px) { .float-badge { display: none; } }

  /* ===== REDUCED MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
    [data-reveal] { opacity: 1; transform: none; transition: none; }
    .app-window { transform: none; }
    .window-glow { animation: none; opacity: 1; }
  }
</style>

<script>
  // Scroll-triggered reveal
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); observer.unobserve(e.target); } }),
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));

  // Nav scroll state
  const nav = document.getElementById('nav');
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 60);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  menuBtn?.addEventListener('click', () => {
    const open = mobileMenu?.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded', String(open));
  });
  mobileMenu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => { mobileMenu.classList.remove('open'); menuBtn?.setAttribute('aria-expanded', 'false'); });
  });


  // ── Domain-for-sale popup ──────────────────────────────────
  // Shown once per session on entry. connectea.net is for sale.
  (() => {
    try { if (sessionStorage.getItem('fs-dismissed') === '1') return; } catch (_) {}

    const lang = document.documentElement.lang || 'en';
    const i18n = {
      en: {
        eyebrow: 'Domain for sale',
        title: 'connectea.net is for sale',
        body: 'This domain is available for purchase. If you are interested in buying it, get in touch and we will be happy to talk.',
        contact: 'Contact contact@connectea.net',
        dismiss: 'Maybe later',
        subject: 'Interested in buying connectea.net',
      },
      es: {
        eyebrow: 'Dominio en venta',
        title: 'connectea.net está en venta',
        body: 'Este dominio está disponible para su compra. Si te interesa adquirirlo, ponte en contacto y hablamos.',
        contact: 'Contactar contact@connectea.net',
        dismiss: 'Quizás más tarde',
        subject: 'Interesado en comprar connectea.net',
      },
      zh: {
        eyebrow: '域名出售',
        title: 'connectea.net 域名出售',
        body: '此域名现可出售。如果您有意购买，请与我们联系，我们很乐意洽谈。',
        contact: '联系 contact@connectea.net',
        dismiss: '以后再说',
        subject: '有意购买 connectea.net',
      },
    };
    const tx = i18n[lang] || i18n.en;

    const overlay   = document.getElementById('for-sale-overlay');
    if (!overlay) return;
    const contactBtn = document.getElementById('fs-contact-btn');

    document.getElementById('fs-eyebrow').textContent = tx.eyebrow;
    document.getElementById('fs-title').textContent = tx.title;
    document.getElementById('fs-body').textContent = tx.body;
    document.getElementById('fs-contact-text').textContent = tx.contact;
    document.getElementById('fs-dismiss-text').textContent = tx.dismiss;
    contactBtn.setAttribute('href', 'mailto:contact@connectea.net?subject=' + encodeURIComponent(tx.subject));

    const close = () => {
      overlay.hidden = true;
      try { sessionStorage.setItem('fs-dismissed', '1'); } catch (_) {}
    };
    document.getElementById('fs-dismiss-btn').addEventListener('click', close);
    document.getElementById('fs-close-btn').addEventListener('click', close);
    contactBtn.addEventListener('click', () => { try { sessionStorage.setItem('fs-dismissed', '1'); } catch (_) {} });
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

    overlay.hidden = false;
  })();
</script>
